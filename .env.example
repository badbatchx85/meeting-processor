# ============================================================
# Meeting Processor — variáveis de ambiente
# ============================================================
# Copie este arquivo para `.env` e ajuste os valores. O `.env`
# está no `.gitignore` e não é versionado.

# ----- LLM -----
# Provedor de resumo: "anthropic" (Claude), "openai" (OpenAI/compatíveis),
# "gemini" (Google), "local" (Ollama) ou "none" (sem IA: só transcreve).
# Também alterável pela interface web.
MEETING_LLM_PROVIDER=anthropic

# Claude — necessário quando MEETING_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# MEETING_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI e compatíveis — necessário quando MEETING_LLM_PROVIDER=openai
OPENAI_API_KEY=
# MEETING_OPENAI_MODEL=gpt-4o
# Troque a base URL para usar outro serviço compatível:
#   OpenRouter: https://openrouter.ai/api/v1   (modelo ex.: openai/gpt-4o)
#   Groq:       https://api.groq.com/openai/v1
#   DeepSeek:   https://api.deepseek.com/v1     (modelo: deepseek-chat)
#   xAI/Grok:   https://api.x.ai/v1             (modelo: grok-2-latest)
# MEETING_OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini — necessário quando MEETING_LLM_PROVIDER=gemini
GEMINI_API_KEY=
# MEETING_GEMINI_MODEL=gemini-2.0-flash

# ----- Ollama (LLM local) -----
# Necessário só quando MEETING_LLM_PROVIDER=local
# MEETING_OLLAMA_BASE_URL=http://localhost:11434
# MEETING_OLLAMA_MODEL=qwen2.5:14b
# MEETING_OLLAMA_TEMPERATURE=0.2
# MEETING_OLLAMA_NUM_CTX=16384
# MEETING_OLLAMA_REQUEST_TIMEOUT=600

# ----- Caminhos (override do config.yaml) -----
# MEETING_WATCH_DIR=C:\Users\SEU_USUARIO\Videos\OBS
# MEETING_VAULT_DIR=./vault

# ----- Whisper -----
# MEETING_WHISPER_BACKEND=auto
# MEETING_WHISPER_MODEL=large
# MEETING_WHISPER_LANGUAGE=pt
# MEETING_WHISPER_DEVICE=auto

# ----- Logging -----
# MEETING_LOG_LEVEL=INFO
