# ============================================================
# Meeting Processor — variáveis de ambiente
# ============================================================
# Copie este arquivo para `.env` e ajuste os valores. O `.env`
# está no `.gitignore` e não é versionado.

# ----- LLM -----
# Provedor de resumo: "anthropic" (Claude API) ou "local" (Ollama)
MEETING_LLM_PROVIDER=anthropic

# Necessário só quando MEETING_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Override opcional do modelo Claude
# MEETING_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ----- Ollama (LLM local) -----
# Necessário só quando MEETING_LLM_PROVIDER=local
# MEETING_OLLAMA_BASE_URL=http://localhost:11434
# MEETING_OLLAMA_MODEL=qwen2.5:14b
# MEETING_OLLAMA_TEMPERATURE=0.2
# MEETING_OLLAMA_NUM_CTX=16384
# MEETING_OLLAMA_REQUEST_TIMEOUT=600

# ----- Caminhos (override do config.yaml) -----
# MEETING_WATCH_DIR=C:\Users\SEU_USUARIO\Videos\OBS
# MEETING_VAULT_DIR=./vault

# ----- Whisper -----
# MEETING_WHISPER_MODEL=large
# MEETING_WHISPER_LANGUAGE=pt
# MEETING_WHISPER_DEVICE=auto

# ----- Logging -----
# MEETING_LOG_LEVEL=INFO
